NODE_ENV=production
PORT=3001
DATABASE_URL=postgresql://nuar_crm:change-me@127.0.0.1:5432/nuar_crm?schema=public

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-long-password
JWT_SECRET=change-me-at-least-32-random-characters

# Comma-separated frontend origins allowed to call the backend.
CORS_ORIGIN=https://crm.example.com,https://your-vercel-app.vercel.app

# Optional automation / messaging integrations. Leave empty if unused.
SMSAPI_TOKEN=
SMSAPI_FROM=
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_CHAT_ID=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
