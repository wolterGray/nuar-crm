// backend/prisma/schema.prisma
// Prisma schema for the custom backend (PostgreSQL).
// Adjust the connection URL in .env (DATABASE_URL) to match your PostgreSQL instance.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Minimal set of tables needed by the CRM. Extend as required.
model Client {
  id              Int      @id @default(autoincrement())
  name            String
  messageName     String?
  phone           String?
  email           String?  @unique
  birthday        String?
  instagram       String?
  telegram        String?
  source          String?
  messageLanguage String?
  preference      String?
  status          String?
  tags            String?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  visits          Visit[]
  clientPackages  ClientPackage[]
  certificates    Certificate[] @relation("CertificateBuyer")
  certificateUses Certificate[] @relation("CertificateRecipient")
  communicationLog CommunicationLog[]
}

model Service {
  id              Int      @id @default(autoincrement())
  name            String
  category        String?
  description     String?
  color           String?
  variants        Json?
  status          String?
  bookingSettings Json?
  buffers         Json?
  siteVisible     Boolean?
  price           Decimal?
  durationMin     Int?
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  visits          Visit[]
}

model Employee {
  id                     Int      @id @default(autoincrement())
  name                   String
  phone                  String?
  email                  String?  @unique
  role                   String?
  status                 String?
  color                  String?
  commissionRate         Decimal?
  shiftStart             String?
  shiftEnd               String?
  payrollSchedule        String?
  siteBookingSlotMinutes Int?
  services               Json?
  siteVisible            Boolean?
  pricing                Json?
  payrollSettings        Json?
  shifts                 Json?
  payload                Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  visits                 Visit[]
  soldClientPackages     ClientPackage[]
  soldCertificates       Certificate[]
  payrollRecords         PayrollRecord[]
}

model Visit {
  id          Int      @id @default(autoincrement())
  clientId    Int?
  serviceId   Int?
  employeeId  Int?
  scheduledAt DateTime?
  notes       String?
  calendarEntryId Int?
  recordType  String?
  payload     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client    Client?  @relation(fields: [clientId], references: [id])
  service   Service? @relation(fields: [serviceId], references: [id])
  employee  Employee? @relation(fields: [employeeId], references: [id])
  packageUsages ClientPackageUsage[]
  certificateUsages CertificateUsage[]
}

model CalendarEntry {
  id          Int      @id @default(autoincrement())
  kind        String?
  date        String?
  time        String?
  status      String?
  visitId     Int?
  payload     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          Int      @id @default(autoincrement())
  type        String?
  title       String
  description String?
  note        String?
  dueDate     DateTime?
  priority    String?
  status      String?
  sortOrder   Int?
  completed   Boolean  @default(false)
  payload     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WaitlistEntry {
  id                Int      @id @default(autoincrement())
  clientId          Int?
  clientName        String?
  preferredDate     String?
  preferredMaster   String?
  preferredService  String?
  preferredTimeFrom String?
  preferredTimeTo   String?
  status            String?
  note              String?
  lastOfferedAt     DateTime?
  lastOfferedSlot   Json?
  payload           Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Supply {
  id        Int      @id @default(autoincrement())
  name      String
  stock     Decimal?
  minStock  Decimal?
  unit      String?
  cost      Decimal?
  note      String?
  orderUrl  String?
  payload   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MessageTemplate {
  id        Int      @id @default(autoincrement())
  name      String
  channel   String?
  language  String?
  audience  String?
  purpose   String?
  subject   String?
  body      String
  payload   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunicationLog {
  id           Int      @id @default(autoincrement())
  clientId     Int?
  clientName   String?
  channel      String?
  templateName String?
  body         String?
  payload      Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client       Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
}

model SystemState {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Package {
  id             Int      @id @default(autoincrement())
  name           String
  service        String?
  visitsCount    Int?
  price          Decimal?
  validityDays   Int?
  status         String?
  active         Boolean  @default(true)
  payload        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  clientPackages ClientPackage[]
}

model ClientPackage {
  id              Int      @id @default(autoincrement())
  clientId        Int?
  packageId       Int?
  employeeId      Int?
  clientName      String?
  packageName     String?
  service         String?
  totalVisits     Int?
  remainingVisits Int?
  price           Decimal?
  purchaseDate    String?
  expiryDate      String?
  payment         String?
  status          String?
  writeOffHistory Json?
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  client          Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  package         Package? @relation(fields: [packageId], references: [id], onDelete: SetNull)
  employee        Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  usages          ClientPackageUsage[]
}

model ClientPackageUsage {
  id              Int      @id @default(autoincrement())
  clientPackageId Int
  visitId         Int?
  sessionsUsed    Int      @default(1)
  usedAt          DateTime @default(now())
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  clientPackage   ClientPackage @relation(fields: [clientPackageId], references: [id], onDelete: Cascade)
  visit           Visit? @relation(fields: [visitId], references: [id], onDelete: SetNull)
}

model Certificate {
  id               Int      @id @default(autoincrement())
  code             String   @unique
  clientId         Int?
  recipientId      Int?
  employeeId       Int?
  saleVisitId      Int?
  clientName       String?
  recipientName    String?
  nominal          Decimal?
  remainingBalance Decimal?
  purchaseDate     String?
  usedDate         String?
  expiryDate       String?
  payment          String?
  status           String?
  note             String?
  payload          Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  client           Client? @relation("CertificateBuyer", fields: [clientId], references: [id], onDelete: SetNull)
  recipient        Client? @relation("CertificateRecipient", fields: [recipientId], references: [id], onDelete: SetNull)
  employee         Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
  usages           CertificateUsage[]
}

model CertificateUsage {
  id            Int      @id @default(autoincrement())
  certificateId Int
  visitId       Int?
  amount        Decimal?
  usedAt        DateTime @default(now())
  payload       Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  certificate   Certificate @relation(fields: [certificateId], references: [id], onDelete: Cascade)
  visit         Visit? @relation(fields: [visitId], references: [id], onDelete: SetNull)
}

model DayCloseRecord {
  id             Int      @id @default(autoincrement())
  date           String   @unique
  cash           Decimal?
  card           Decimal?
  blik           Decimal?
  certificates   Decimal?
  packages       Decimal?
  total          Decimal?
  status         String?
  note           String?
  payload        Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PayrollRecord {
  id          Int      @id @default(autoincrement())
  employeeId  Int?
  employeeName String?
  startDate   String?
  endDate     String?
  periodKey   String   @unique
  amount      Decimal?
  status      String?
  paidAt      DateTime?
  note        String?
  payload     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  employee    Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)
}
