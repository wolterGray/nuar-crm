// backend/prisma/schema.prisma
// Prisma schema for the custom backend (PostgreSQL).
// Adjust the connection URL in .env (DATABASE_URL) to match your PostgreSQL instance.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// Minimal set of tables needed by the CRM. Extend as required.
model Client {
  id              Int      @id @default(autoincrement())
  name            String
  messageName     String?
  phone           String?
  email           String?  @unique
  birthday        String?
  instagram       String?
  telegram        String?
  source          String?
  messageLanguage String?
  preference      String?
  status          String?
  tags            String?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  visits          Visit[]
}

model Service {
  id              Int      @id @default(autoincrement())
  name            String
  category        String?
  description     String?
  color           String?
  variants        Json?
  status          String?
  bookingSettings Json?
  buffers         Json?
  siteVisible     Boolean?
  price           Decimal?
  durationMin     Int?
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  visits          Visit[]
}

model Employee {
  id                     Int      @id @default(autoincrement())
  name                   String
  phone                  String?
  email                  String?  @unique
  role                   String?
  status                 String?
  color                  String?
  commissionRate         Decimal?
  shiftStart             String?
  shiftEnd               String?
  payrollSchedule        String?
  siteBookingSlotMinutes Int?
  services               Json?
  siteVisible            Boolean?
  pricing                Json?
  payrollSettings        Json?
  shifts                 Json?
  payload                Json?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  visits                 Visit[]
}

model Visit {
  id          Int      @id @default(autoincrement())
  clientId    Int?
  serviceId   Int?
  employeeId  Int?
  scheduledAt DateTime?
  notes       String?
  calendarEntryId Int?
  recordType  String?
  payload     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client    Client?  @relation(fields: [clientId], references: [id])
  service   Service? @relation(fields: [serviceId], references: [id])
  employee  Employee? @relation(fields: [employeeId], references: [id])
}

model CalendarEntry {
  id          Int      @id @default(autoincrement())
  kind        String?
  date        String?
  time        String?
  status      String?
  visitId     Int?
  payload     Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Task {
  id          Int      @id @default(autoincrement())
  type        String?
  title       String
  description String?
  note        String?
  dueDate     DateTime?
  priority    String?
  status      String?
  sortOrder   Int?
  completed   Boolean  @default(false)
  payload     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WaitlistEntry {
  id                Int      @id @default(autoincrement())
  clientId          Int?
  clientName        String?
  preferredDate     String?
  preferredMaster   String?
  preferredService  String?
  preferredTimeFrom String?
  preferredTimeTo   String?
  status            String?
  note              String?
  lastOfferedAt     DateTime?
  lastOfferedSlot   Json?
  payload           Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Supply {
  id        Int      @id @default(autoincrement())
  name      String
  stock     Decimal?
  minStock  Decimal?
  unit      String?
  cost      Decimal?
  note      String?
  orderUrl  String?
  payload   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
