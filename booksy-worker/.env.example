SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

BOOKSY_EMAIL=your-booksy-login@email.com
BOOKSY_PASSWORD=your-booksy-password

# Optional: direct login URL if Booksy changes auth flow
BOOKSY_LOGIN_URL=https://booksy.com/pro/login

# Optional business context for multi-location accounts
BOOKSY_BUSINESS_ID=

# Worker identity shown in booksy_sync_jobs.locked_by
WORKER_ID=local-booksy-worker

# Poll interval for queued jobs
WORKER_POLL_INTERVAL_MS=5000

# Set to 1 to run Playwright in headed mode while tuning selectors
BOOKSY_HEADLESS=1

# Set to 1 to skip Playwright and simulate success (local plumbing test only)
BOOKSY_DRY_RUN=0
